services:
  registry:
    image: registry:2
    container_name: registry
    restart: always
    ports:
      - "5005:5005"
    environment:
      - REGISTRY_HTTP_ADDR=0.0.0.0:5005
    volumes:
      - /root/registry:/var/lib/registry
    networks:
      - ci-network

  jenkins:
    build: .
    image: my-jenkins
    container_name: jenkins
    restart: always
    user: root

    environment:
      - JAVA_OPTS=-Dhudson.model.DownloadService.noSignatureCheck=true
      - DOCKER_HOST=unix:///var/run/docker.sock
      - JENKINS_OPTS=--prefix=/jenkins

    ports:
      - "8080:8080"
      - "50000:50000"

    volumes:
      - /root/jenkins_home:/var/jenkins_home
      - /var/run/docker.sock:/var/run/docker.sock

    networks:
      - ci-network

networks:
  ci-network:
    external: true
